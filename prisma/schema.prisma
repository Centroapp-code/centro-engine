generator client {
  provider = "prisma-client"
  output   = "../lib/db/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(cuid())
  clerkId             String          @unique
  email               String          @unique
  role                Role            @default(CUSTOMER)
  onboardingCompleted Boolean         @default(false)
  createdAt           DateTime        @default(now())
  companyMemberships  CompanyMember[]

  @@map("users")
}

model Company {
  id                String             @id @default(cuid())
  name              String
  industry          String?
  companySize       String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  aiAgents          AIAgent[]
  calls             Call[]
  members           CompanyMember[]
  opportunities     Opportunity[]
  phoneIntegrations PhoneIntegration[]
  industryProfile   IndustryProfile?

  @@map("companies")
}

/// *
///  * Per-company configuration for industry-specific context: which vendor
///  * categories are relevant, how to weight opportunity scoring, and any
///  * terminology overrides. Keeps industry logic in data, not hardcoded in
///  * application code.
model IndustryProfile {
  id                String   @id @default(cuid())
  companyId         String   @unique
  industry          String
  vendorCategories  Json     @default("[]")
  scoringPriorities Json     @default("[]")
  terminology       Json     @default("{}")
  goals             Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("industry_profiles")
}

model CompanyMember {
  userId    String
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
  @@map("company_members")
}

model AIAgent {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  greeting           String
  instructions       String
  personality        String?
  transferRules      String?
  screeningQuestions Json     @default("[]")
  active             Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@map("ai_agents")
}

model PhoneIntegration {
  id          String                 @id @default(cuid())
  companyId   String
  phoneNumber String                 @unique
  provider    PhoneProvider          @default(TWILIO)
  status      PhoneIntegrationStatus @default(PENDING)
  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("phone_integrations")
}

model Call {
  id             String        @id @default(cuid())
  companyId      String
  callerName     String?
  callerPhone    String
  duration       Int?
  transcript     String?
  createdAt      DateTime      @default(now())
  providerCallId String?       @unique
  status         CallStatus    @default(PENDING)
  analysis       CallAnalysis?
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?

  @@index([companyId])
  @@map("calls")
}

/// *
///  * The AI's structured read on a Call — one per Call, produced by the future
///  * AI analysis step. Kept separate from Call so the raw call record and the
///  * AI's interpretation of it can evolve independently.
model CallAnalysis {
  id               String       @id @default(cuid())
  callId           String       @unique
  category         CallCategory @default(OTHER)
  summary          String?
  recommendation   String?
  opportunityScore Int?
  extractedInfo    Json         @default("{}")
  createdAt        DateTime     @default(now())
  call             Call         @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("call_analyses")
}

model Opportunity {
  id                String              @id @default(cuid())
  companyId         String
  callId            String?             @unique
  name              String?
  email             String?
  phone             String?
  opportunityType   String?
  score             Int?
  priority          OpportunityPriority @default(MEDIUM)
  status            OpportunityStatus   @default(NEW)
  recommendedAction String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  call              Call?               @relation(fields: [callId], references: [id], onDelete: Cascade)
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("opportunities")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum PhoneProvider {
  TWILIO
}

enum PhoneIntegrationStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum CallStatus {
  PENDING
  ANALYZED
  ARCHIVED
}

enum CallCategory {
  VENDOR
  PARTNERSHIP
  OTHER
}

enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
}

enum OpportunityStatus {
  NEW
  REVIEWED
  FLAGGED
  DISMISSED
}
