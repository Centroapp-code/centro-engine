# Database (Neon Postgres — https://neon.tech)
# Include `?sslmode=require`; Neon rejects unencrypted connections.
DATABASE_URL="postgresql://user:password@ep-example-000000.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Optional, only needed for `prisma migrate dev` to create/reset its shadow
# database. Not required in production (`prisma migrate deploy` doesn't use it).
SHADOW_DATABASE_URL=

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook (Dashboard → Webhooks → your endpoint → Signing Secret)
# Used by app/api/webhooks/clerk to assign the default CUSTOMER role on sign-up.
CLERK_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
